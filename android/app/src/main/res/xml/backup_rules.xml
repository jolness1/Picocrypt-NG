<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude all file storage -->
    <exclude domain="file" path="."/>
    
    <!-- Exclude all SharedPreferences -->
    <exclude domain="sharedpref" path="."/>
    
    <!-- Exclude all databases -->
    <exclude domain="database" path="."/>
    
    <!-- Exclude root-level files -->
    <exclude domain="root" path="."/>
    
    <!-- Explicitly exclude the picocrypt_files directory -->
    <exclude domain="file" path="picocrypt_files/"/>
</full-backup-content>
